# ─── Travinno Production Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your Hostinger MySQL credentials.
# NEVER commit .env to Git — it is listed in .gitignore.

# ── MySQL Database (Hostinger) ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
